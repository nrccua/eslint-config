{
  "author": "Jon Cursi <jon.cursi@encoura.org>",
  "bugs": {
    "email": "jon.cursi@encoura.org",
    "url": "https://github.com/nrccua/eslint-config/issues"
  },
  "contributors": [
    "Jon Cursi <jon.cursi@encoura.org>",
    "Adam Weeden <adam.weeden@encoura.org>"
  ],
  "dependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-mdx": "^3.8.1",
    "eslint-plugin-new-with-error": "^5.0.0",
    "eslint-plugin-no-loops": "^0.4.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regex": "^1.10.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-storybook": "^10.4.3",
    "prettier": "^3.8.4",
    "storybook": "^10.4.3"
  },
  "description": "Encoura's preferred configs for TypeScript, Prettier, ESLint, CommitLint, and MarkdownLint.",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "clean-publish": "^5.2.2",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.1.2",
    "markdownlint-cli": "^0.47.0",
    "npm-run-all2": "^8.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "homepage": "https://github.com/nrccua/eslint-config#readme",
  "keywords": [
    "commitlint",
    "eslint",
    "eslint-config",
    "markdownlint",
    "prettier",
    "typescript"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,json,md,ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx}": "npm run test:lint:js",
    "*.{ts,tsx}": "npm run test:lint:ts",
    "*.{md}": "npm run test:lint:md"
  },
  "main": "index.js",
  "name": "@encoura/eslint-config",
  "overrides": {
    "eslint-config-airbnb": {
      "eslint": "$eslint",
      "eslint-plugin-react-hooks": "$eslint-plugin-react-hooks"
    },
    "eslint-config-airbnb-base": {
      "eslint": "$eslint"
    },
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "rimraf": "^6.0.1",
    "test-exclude": "^7.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nrccua/eslint-config.git"
  },
  "scripts": {
    "build": "npm-run-all2 build:*",
    "build:clean": "rimraf dist && mkdir dist",
    "build:docs": "cp -rf CHANGELOG.md LICENSE README.md dist",
    "build:package_json": "clear-package-json package.json -o dist/package.json",
    "build:src": "cp -rf src/* dist",
    "prepare": "husky",
    "test": "npm-run-all2 test:**",
    "test:lint:js": "eslint --quiet \"**/*.{js,jsx}\"",
    "test:lint:nest": "eslint --ext .ts --quiet -c eslint.nest.config.js 'examples/Nest'",
    "test:lint:ts": "eslint --quiet --ignore-pattern '**/Nest/*' \"**/*.{ts,tsx}\"",
    "test:lint:md": "markdownlint README.md .github/**/*.md --config ./src/markdownlint.config.json",
    "test:prettier": "prettier --check .",
    "test:tsconfig": "tsc --noEmit",
    "test:unit": "vitest run --environment jsdom"
  },
  "version": "4.0.0"
}
